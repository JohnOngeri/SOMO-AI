# ── Core ────────────────────────────────────────────────────────────────
NODE_ENV=development
API_PORT=4000

# ── Database / cache / object store (matches infra/docker-compose.yml) ──
DATABASE_URL=postgresql://somo:somo@localhost:5432/somo
REDIS_URL=redis://localhost:6379
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=somo
S3_SECRET_KEY=somo-dev-secret
S3_BUCKET_PACKS=somo-packs
PACKS_STORAGE_DIR=./storage

# ── Auth (phone + OTP) ──────────────────────────────────────────────────
JWT_SECRET=dev-only-change-me
JWT_REFRESH_SECRET=dev-only-change-me-too
OTP_TTL_SECONDS=300

# ── Pack signing + offline entitlement tokens (ed25519, base64) ─────────
# Generate with: node -e "const {generateKeyPairSync}=require('crypto');const k=generateKeyPairSync('ed25519');console.log(k.privateKey.export({type:'pkcs8',format:'der'}).toString('base64'));console.log(k.publicKey.export({type:'spki',format:'der'}).toString('base64'))"
PACK_SIGNING_PRIVATE_KEY=
PACK_SIGNING_PUBLIC_KEY=
ENTITLEMENT_SIGNING_PRIVATE_KEY=
ENTITLEMENT_SIGNING_PUBLIC_KEY=

# ── Payments (sandbox keys only — never commit live keys) ───────────────
PAYMENT_PROVIDER=sandbox
FLUTTERWAVE_SECRET_KEY=
FLUTTERWAVE_WEBHOOK_HASH=
PAYSTACK_SECRET_KEY=
PAYSTACK_WEBHOOK_SECRET=

# ── SMS / USSD (Africa's Talking sandbox) ───────────────────────────────
AT_USERNAME=sandbox
AT_API_KEY=
AT_SHORTCODE=
AT_USSD_SERVICE_CODE=*384*1234#

# ── AI provider ──────────────────────────────────────────────────────────
AI_PROVIDER=anthropic
ANTHROPIC_API_KEY=
AI_MODEL_FAST=claude-haiku-4-5
AI_MODEL_QUALITY=claude-sonnet-5
